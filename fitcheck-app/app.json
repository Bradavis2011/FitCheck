{
  "expo": {
    "name": "Or This? AI Outfit Feedback",
    "slug": "orthis",
    "scheme": "orthis",
    "version": "1.2.1",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bd6e74d0-ce99-492d-aad3-ada5bad060d4"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E85D4C"
    },
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.bradavis.orthis",
      "associatedDomains": ["applinks:orthis.app"],
      "infoPlist": {
        "NSCameraUsageDescription": "Or This? uses your camera to take photos of your outfit for AI-powered style analysis.",
        "NSPhotoLibraryUsageDescription": "Or This? accesses your photo library so you can select outfit photos for AI style analysis.",
        "NSPhotoLibraryAddUsageDescription": "Or This? saves your outfit score cards to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bradavis.orthis",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E85D4C"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "orthis.app", "pathPrefix": "/s/" },
            { "scheme": "https", "host": "orthis.app", "pathPrefix": "/invite/" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "platforms": ["ios", "android"],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#E85D4C",
          "iosDisplayInForeground": true
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "outfitcheck",
          "project": "orthis-app"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1244039707249288~4992117276",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bd6e74d0-ce99-492d-aad3-ada5bad060d4"
      }
    },
    "owner": "outfitcheck"
  }
}
