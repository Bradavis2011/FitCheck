# Entire directories the Expo build does not need
fitcheck-api/
orthis-web/
test-app/
lovable-mockup/
pitch-materials/
Branding/
Monetization/
docs/
.github/
.vercel/
.claude/

# Root-level dirs that are not part of the app (anchored to repo root)
/prisma/
/src/
/scripts/

# Node modules — EAS reinstalls from package-lock.json
node_modules/

# Build artifacts and caches
dist/
web-build/
.expo/

# Store assets (screenshots, reviewer notes — not needed for build)
fitcheck-app/store-assets/

# Native build dirs (regenerated by EAS)
fitcheck-app/android/
fitcheck-app/ios/

# Large/unnecessary file types
*.pptx
*.zip
*.log
*.tsbuildinfo

# Local config
.env
.env.*
.railwayignore
tsc_*.txt
.DS_Store
